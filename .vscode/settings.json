{
  // Treat .feature files as "feature" language (used by Cucumber extensions)
  "[feature]": {
    "editor.formatOnSave": false
  },
  "files.associations": {
    "*.feature": "feature"
  },

  // CucumberAutoComplete+ (for C# step navigation)
  "cucumberautocomplete.steps": [
    "**/StepDefinitions/**/*.cs"
  ],
  "cucumberautocomplete.syncfeatures": "**/Features/**/*.feature",
  "cucumberautocomplete.strictGherkinCompletion": false,
  "cucumberautocomplete.customParameters": [
    { "parameter": "{int}",    "value": "\\d+" },
    { "parameter": "{long}",   "value": "\\d+" },
    { "parameter": "{string}", "value": "\".+\"" }
  ],

  // Official Cucumber extension (cucumber.cucumber-language-server)
  "cucumber.glue": [
    "**/StepDefinitions/**/*.cs"
  ],
  "cucumber.features": [
    "**/Features/**/*.feature"
  ]
}
